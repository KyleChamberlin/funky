amends "package://github.com/jdx/hk/releases/download/v1.42.0/hk@1.42.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.42.0/hk@1.42.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["clippy"] = (Builtins.cargo_clippy) {
    check = "cargo clippy --manifest-path {{workspace_indicator}} --all-features -- -Dwarnings"
    fix =
      "cargo clippy --manifest-path {{workspace_indicator}} --all-features --fix --allow-dirty --allow-staged -- -Dwarnings"
  }
  ["cargo_fmt"] = Builtins.cargo_fmt
  ["pkl"] = Builtins.pkl
  ["pkl_format"] = Builtins.pkl_format
  ["actionlint"] = Builtins.actionlint
  ["yamllint"] = Builtins.yamllint
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
